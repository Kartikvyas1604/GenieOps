{
  "name": "genieops",
  "displayName": "GenieOps",
  "description": "🧞 The world's most powerful AI DevOps automation platform. Natural language commands powered by Gemini AI for all DevOps, cloud, and integration tasks.",
  "version": "0.1.0",
  "publisher": "genieops",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kartikvyas1604/GenieOps.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Programming Languages"
  ],
  "keywords": [
    "devops",
    "aws",
    "azure",
    "gcp",
    "kubernetes",
    "docker",
    "ci/cd",
    "ai",
    "automation"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "genieops.runCommand",
        "title": "GenieOps: Run Command",
        "icon": "$(play)"
      },
      {
        "command": "genieops.openChat",
        "title": "GenieOps: Open Chat Panel",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "genieops.connectService",
        "title": "GenieOps: Connect Service",
        "icon": "$(plug)"
      },
      {
        "command": "genieops.disconnectService",
        "title": "GenieOps: Disconnect Service",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "genieops.showConnections",
        "title": "GenieOps: Show Connections",
        "icon": "$(server)"
      },
      {
        "command": "genieops.analyzeProject",
        "title": "GenieOps: Analyze Project",
        "icon": "$(search)"
      },
      {
        "command": "genieops.generateDockerfile",
        "title": "GenieOps: Generate Dockerfile",
        "icon": "$(file-code)"
      },
      {
        "command": "genieops.generateCICD",
        "title": "GenieOps: Generate CI/CD Pipeline",
        "icon": "$(github-action)"
      },
      {
        "command": "genieops.deployToCloud",
        "title": "GenieOps: Deploy to Cloud",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "genieops.vibeCode",
        "title": "GenieOps: Vibe Code New Project",
        "icon": "$(sparkle)"
      },
      {
        "command": "genieops.cloneEnvironment",
        "title": "GenieOps: Clone Environment",
        "icon": "$(copy)"
      },
      {
        "command": "genieops.manageSecrets",
        "title": "GenieOps: Manage Secrets",
        "icon": "$(key)"
      },
      {
        "command": "genieops.refreshConnections",
        "title": "Refresh Connections",
        "icon": "$(refresh)"
      },
      {
        "command": "genieops.refreshResources",
        "title": "Refresh Resources",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "genieops",
          "title": "🧞 GenieOps",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "genieops": [
        {
          "id": "genieops.connectionsView",
          "name": "Connections",
          "icon": "$(plug)"
        },
        {
          "id": "genieops.pipelinesView",
          "name": "Pipelines",
          "icon": "$(github-action)"
        },
        {
          "id": "genieops.resourcesView",
          "name": "Cloud Resources",
          "icon": "$(cloud)"
        },
        {
          "id": "genieops.historyView",
          "name": "History",
          "icon": "$(history)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "genieops.connectionsView",
        "contents": "No services connected yet.\n[Connect Service](command:genieops.connectService)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "genieops.refreshConnections",
          "when": "view == genieops.connectionsView",
          "group": "navigation"
        },
        {
          "command": "genieops.connectService",
          "when": "view == genieops.connectionsView",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "genieops.runCommand",
          "when": "true"
        }
      ]
    },
    "configuration": {
      "title": "GenieOps",
      "properties": {
        "genieops.aiProvider": {
          "type": "string",
          "default": "google",
          "enum": [
            "anthropic",
            "openai",
            "google",
            "mistral",
            "local"
          ],
          "description": "Primary AI provider for command processing"
        },
        "genieops.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key for Claude models"
        },
        "genieops.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key for GPT models"
        },
        "genieops.googleApiKey": {
          "type": "string",
          "default": "",
          "description": "Google API key for Gemini models (Primary AI)"
        },
        "genieops.enableParallelModels": {
          "type": "boolean",
          "default": false,
          "description": "Run multiple AI models in parallel for complex tasks"
        },
        "genieops.enableTelemetry": {
          "type": "boolean",
          "default": false,
          "description": "Enable anonymous usage telemetry (GDPR compliant)"
        },
        "genieops.defaultCloud": {
          "type": "string",
          "default": "aws",
          "enum": [
            "aws",
            "gcp",
            "azure"
          ],
          "description": "Default cloud provider for deployments"
        },
        "genieops.autoAnalyzeProject": {
          "type": "boolean",
          "default": true,
          "description": "Automatically analyze project on workspace open"
        },
        "genieops.secretsBackend": {
          "type": "string",
          "default": "vscode",
          "enum": [
            "vscode",
            "aws-secrets-manager",
            "hashicorp-vault",
            "doppler"
          ],
          "description": "Backend for secrets management"
        },
        "genieops.mcpServerPort": {
          "type": "number",
          "default": 3000,
          "description": "Port for MCP server communication"
        }
      }
    },
    "keybindings": [
      {
        "command": "genieops.runCommand",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      },
      {
        "command": "genieops.openChat",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "webpack --mode production",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vscode/test-electron": "^2.3.8",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^13.0.1",
    "eslint": "^8.56.0",
    "mocha": "^10.2.0",
    "prettier": "^3.2.4",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.6.5",
    "dockerode": "^4.0.2",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.26.0",
    "ws": "^8.16.0"
  }
}